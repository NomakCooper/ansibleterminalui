---
import ChangelogFeed from '../components/ChangelogFeed';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { fallbackReleases } from '../data/releases';
import Base from '../layouts/Base.astro';

const changelogUrl = new URL('/changelog/', Astro.site).toString();
const structuredData = [
  {
    '@type': 'BreadcrumbList',
    '@id': `${changelogUrl}#breadcrumbs`,
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', Astro.site).toString() },
      { '@type': 'ListItem', position: 2, name: 'Changelog', item: changelogUrl },
    ],
  },
  {
    '@type': 'CollectionPage',
    '@id': `${changelogUrl}#collection`,
    url: changelogUrl,
    name: 'ansi-tui changelog',
    description: 'Release history and changelog entries for ansi-tui, synced from GitHub Releases with bundled fallback notes.',
    about: { '@type': 'SoftwareApplication', name: 'ansi-tui' },
  },
];
---

<Base
  title="ansi-tui Changelog and Releases"
  description="Read ansi-tui release history, changelog entries, fixes, and feature updates sourced from GitHub Releases."
  ogImageAlt="ansi-tui changelog page preview"
  structuredData={structuredData}
>
  <Header />
  <main>
    <div class="border-b border-zinc-800 bg-zinc-900/30 py-16">
      <div class="section-wrap space-y-4 text-center">
        <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">
          <span class="gradient-text">Changelog</span>
        </h1>
        <p class="text-xl text-zinc-400">Release history for ansi-tui.</p>
      </div>
    </div>

    <section class="py-20">
      <div class="section-wrap max-w-3xl">
        <ChangelogFeed initialReleases={fallbackReleases} client:load />
      </div>
    </section>
  </main>
  <Footer />
</Base>
