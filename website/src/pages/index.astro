---
import FAQAccordion from '../components/FAQAccordion';
import FeaturesGrid from '../components/FeaturesGrid.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import InstallTabs from '../components/InstallTabs';
import KeyboardRef from '../components/KeyboardRef.astro';
import StatsBar from '../components/StatsBar.astro';
import ThemeGallery from '../components/ThemeGallery.astro';
import ToolCoverage from '../components/ToolCoverage.astro';
import WorkflowDiagram from '../components/WorkflowDiagram.astro';
import { faq } from '../data/faq';
import Base from '../layouts/Base.astro';

const homeUrl = new URL('/', Astro.site).toString();
const softwareId = `${homeUrl}#software`;

function faqAnswerText(answer: string, template?: string) {
  return (template ?? answer)
    .replaceAll('{{package}}', '@3a2dev/ansi-tui')
    .replaceAll('{{tarball}}', 'downloaded-package.tgz')
    .replaceAll('{{version}}', 'latest')
    .replaceAll('{{downloadsCompact}}', 'latest monthly downloads')
    .replaceAll('{{downloadsFull}}', 'latest monthly downloads')
    .replaceAll('{{downloadsLabel}}', 'latest monthly downloads');
}

const structuredData = [
  {
    '@type': 'SoftwareApplication',
    '@id': softwareId,
    name: 'ansi-tui',
    alternateName: 'Ansible Terminal User Interface',
    applicationCategory: 'DeveloperApplication',
    applicationSubCategory: 'Terminal User Interface',
    operatingSystem: 'macOS, Linux',
    softwareRequirements: 'Node.js 18+, ansible-core and relevant Ansible CLI tools',
    isAccessibleForFree: true,
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'USD',
    },
    description:
      'Open source Ansible terminal UI for playbooks, vault, lint, inventory, galaxy, builder, test, and more with guided forms, live output, sessions, and offline installation.',
    url: homeUrl,
    downloadUrl: 'https://www.npmjs.com/package/@3a2dev/ansi-tui',
    installUrl: new URL('/install/', Astro.site).toString(),
    codeRepository: 'https://github.com/3A2DEV/ansi-tui',
    license: 'https://github.com/3A2DEV/ansi-tui/blob/main/LICENSE',
    screenshot: [new URL('/banner.png', Astro.site).toString()],
    featureList: [
      'Guided workflows for ansible-playbook, ansible-vault, ansible-lint, inventory, galaxy, and more',
      'Live terminal output with ANSI-aware rendering and job history',
      'Workspace sessions with persistent execution context',
      'Keyboard-first terminal UX with local-first storage',
      'Offline and air-gapped installation support',
    ],
  },
  {
    '@type': 'SoftwareSourceCode',
    '@id': `${homeUrl}#source-code`,
    name: 'ansi-tui',
    codeRepository: 'https://github.com/3A2DEV/ansi-tui',
    programmingLanguage: ['TypeScript', 'JavaScript'],
    runtimePlatform: 'Node.js 18+',
    targetProduct: { '@id': softwareId },
    license: 'https://github.com/3A2DEV/ansi-tui/blob/main/LICENSE',
  },
  {
    '@type': 'FAQPage',
    '@id': `${homeUrl}#faq`,
    mainEntity: faq.map(({ q, a, template }) => ({
      '@type': 'Question',
      name: q,
      acceptedAnswer: {
        '@type': 'Answer',
        text: faqAnswerText(a, template),
      },
    })),
  },
];
---

<Base
  title="ansi-tui: Ansible Terminal UI for Playbooks, Vault, Lint, Inventory and More"
  description="Open source Ansible terminal UI for ansible-playbook, ansible-vault, ansible-lint, inventory, galaxy, builder, test, and more. Guided forms, live output, sessions, and offline install."
  ogImageAlt="ansi-tui terminal UI preview showing guided Ansible workflows"
  structuredData={structuredData}
>
  <Header />
  <main>
    <Hero />
    <StatsBar />
    <FeaturesGrid />
    <WorkflowDiagram />
    <ToolCoverage />
    <ThemeGallery />
    <KeyboardRef />

    <section id="install" class="bg-zinc-900/30 py-20">
      <div class="section-wrap">
        <div class="mb-12 space-y-3 text-center">
          <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">
            Get started in <span class="gradient-text">one command</span>
          </h2>
          <p class="text-lg text-zinc-400">
            Global install, no-install execution, install script, or fully offline deployment for air-gapped environments.
          </p>
        </div>
        <InstallTabs client:load />
        <div class="mt-6 text-center">
          <a href="/install" class="text-sm text-zinc-500 transition-colors hover:text-cyan-400">View full installation guide →</a>
        </div>
      </div>
    </section>

    <section class="py-20">
      <div class="section-wrap">
        <div class="mb-12 space-y-3 text-center">
          <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">
            Frequently asked <span class="gradient-text">questions</span>
          </h2>
        </div>
        <FAQAccordion items={faq} client:load />
      </div>
    </section>

    <section class="py-16">
      <div class="section-wrap">
        <div class="relative overflow-hidden rounded-2xl border border-zinc-800 bg-gradient-to-br from-zinc-900 via-zinc-950 to-zinc-900 p-10 text-center">
          <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_60%_60%_at_50%_100%,rgba(34,211,238,0.07),transparent)]" aria-hidden="true"></div>
          <h2 class="relative mb-3 text-3xl font-bold text-zinc-50">
            Stop memorising flags.<br />
            <span class="gradient-text">Start automating.</span>
          </h2>
          <p class="relative mx-auto mb-8 max-w-md text-zinc-400">
            ansi-tui is free, open source, and ready to work with the Ansible tools you already have installed.
          </p>
          <div class="relative flex flex-wrap items-center justify-center gap-4">
            <a
              href="/install"
              class="inline-flex items-center gap-2 rounded-lg bg-cyan-400 px-6 py-3 font-semibold text-zinc-950 transition-colors hover:bg-cyan-300"
            >
              Install Now
            </a>
            <a
              href="https://github.com/3A2DEV/ansi-tui"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-lg border border-zinc-700 px-6 py-3 font-medium text-zinc-300 transition-all hover:border-zinc-500 hover:text-zinc-50"
            >
              Star on GitHub
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Base>
