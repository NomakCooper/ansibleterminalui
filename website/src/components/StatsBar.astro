---
const npmDownloads = await (async () => {
  try {
    const response = await fetch('https://api.npmjs.org/downloads/point/last-month/%403a2dev%2Fansi-tui');
    if (!response.ok) {
      throw new Error(`npm downloads request failed: ${response.status}`);
    }

    const data = (await response.json()) as { downloads?: number };
    if (typeof data.downloads !== 'number') {
      throw new Error('npm downloads response missing count');
    }

    return new Intl.NumberFormat('en-US', { notation: 'compact', maximumFractionDigits: 1 }).format(data.downloads);
  } catch {
    return 'npm';
  }
})();

const stats = [
  { value: '11', label: 'interactive tools' },
  { value: '60+', label: 'supported actions' },
  { value: '8', label: 'color themes' },
  { value: npmDownloads, label: 'monthly downloads' },
  { value: 'Node 18+', label: 'runtime' },
  { value: 'MIT', label: 'license' },
];
---

<div class="border-y border-zinc-800 bg-zinc-900/50">
  <div class="section-wrap py-6">
    <div class="grid grid-cols-2 gap-6 sm:grid-cols-3 lg:grid-cols-6 lg:gap-0 lg:divide-x lg:divide-zinc-800">
      {stats.map(({ value, label }) => (
        <div class="flex flex-col items-center justify-center text-center lg:px-6">
          <span class="gradient-text font-mono text-2xl font-bold">{value}</span>
          <span class="mt-1 text-xs text-zinc-500">{label}</span>
        </div>
      ))}
    </div>
  </div>
</div>
