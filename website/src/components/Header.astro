---
const navLinks = [
  { href: '/features', label: 'Features' },
  { href: '/install', label: 'Install' },
  { href: '/changelog', label: 'Changelog' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-zinc-800 bg-zinc-950/90 backdrop-blur-sm">
  <div class="section-wrap">
    <nav class="flex h-14 items-center justify-between gap-4">
      <a href="/" class="group flex items-center gap-2">
        <span class="font-mono text-lg font-bold leading-none text-cyan-400">▶</span>
        <span class="font-mono font-bold text-zinc-50 transition-colors group-hover:text-cyan-400">ansi-tui</span>
        <span class="badge-zinc hidden sm:inline-flex" data-package-template="v{{version}}">v0.1.0</span>
      </a>

      <div class="hidden items-center gap-6 md:flex">
        <a
          href="/#features"
          class:list={[
            'text-sm font-medium transition-colors hover:text-cyan-400',
            currentPath === '/' ? 'text-zinc-300' : 'text-zinc-400',
          ]}
        >
          Overview
        </a>
        {navLinks.map(({ href, label }) => (
          <a
            href={href}
            class:list={[
              'text-sm font-medium transition-colors hover:text-cyan-400',
              currentPath === href ? 'text-cyan-400' : 'text-zinc-400',
            ]}
          >
            {label}
          </a>
        ))}
      </div>

      <div class="flex items-center gap-3">
        <span class="hidden items-center gap-1.5 text-xs font-mono text-zinc-500 lg:flex">
          <span class="text-cyan-400">$</span>
          <span>npm i -g @3a2dev/ansi-tui</span>
        </span>

        <a
          href="https://github.com/3A2DEV/ansi-tui"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-1.5 rounded-md border border-zinc-700 bg-zinc-900 px-3 py-1.5 text-sm font-medium text-zinc-300 transition-all hover:border-zinc-500 hover:text-zinc-50"
        >
          <svg class="h-4 w-4" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z" />
          </svg>
          GitHub
        </a>

        <details class="relative md:hidden">
          <summary class="cursor-pointer list-none p-1 text-zinc-400 hover:text-zinc-50">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </summary>
          <div class="absolute right-0 mt-2 w-48 rounded-lg border border-zinc-700 bg-zinc-900 py-1 shadow-xl">
            <a href="/" class="block px-4 py-2 text-sm text-zinc-300 hover:bg-zinc-800 hover:text-zinc-50">Overview</a>
            {navLinks.map(({ href, label }) => (
              <a href={href} class="block px-4 py-2 text-sm text-zinc-300 hover:bg-zinc-800 hover:text-zinc-50">
                {label}
              </a>
            ))}
          </div>
        </details>
      </div>
    </nav>
  </div>
</header>
