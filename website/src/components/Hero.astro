---
import { Image } from 'astro:assets';
import Typewriter from 'astro-typewriter';

const npmDownloadsLabel = await (async () => {
  try {
    const response = await fetch('https://api.npmjs.org/downloads/point/last-month/%403a2dev%2Fansi-tui');
    if (!response.ok) {
      throw new Error(`npm downloads request failed: ${response.status}`);
    }

    const data = (await response.json()) as { downloads?: number };
    if (typeof data.downloads !== 'number') {
      throw new Error('npm downloads response missing count');
    }

    return `${new Intl.NumberFormat('en-US').format(data.downloads)} npm downloads`;
  } catch {
    return 'npm package';
  }
})();
---

<section class="relative overflow-hidden py-16 md:py-24">
  <div class="pointer-events-none absolute inset-0 bg-[linear-gradient(to_right,#18181b_1px,transparent_1px),linear-gradient(to_bottom,#18181b_1px,transparent_1px)] bg-[size:4rem_4rem] opacity-40" aria-hidden="true"></div>
  <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_80%_60%_at_50%_-10%,rgba(34,211,238,0.08),transparent)]" aria-hidden="true"></div>

  <div class="section-wrap relative">
    <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2 lg:gap-16">
      <div class="animate-fade-in space-y-6">
        <a
          href="https://www.npmjs.com/package/@3a2dev/ansi-tui"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-full border border-cyan-400/30 bg-cyan-400/5 px-3 py-1.5 font-mono text-xs text-cyan-400 transition-colors hover:bg-cyan-400/10"
        >
          <span class="h-1.5 w-1.5 animate-pulse rounded-full bg-cyan-400"></span>
          @3a2dev/ansi-tui v0.1.0
        </a>

        <div class="space-y-3">
          <h1 class="max-w-4xl font-mono text-3xl font-bold leading-tight tracking-tight text-cyan-400 sm:text-4xl lg:text-5xl">
            <span class="sr-only">Ansible Terminal User Interface</span>
            <span aria-hidden="true">
              <Typewriter
                messages={["Ansible Terminal User Interface"]}
                writeSpeed={65}
                deleteSpeed={28}
                waitWritten={8000}
                waitDeleted={900}
                class="hero-typewriter"
              />
            </span>
          </h1>
          <p class="max-w-lg text-lg leading-relaxed text-zinc-400 sm:text-xl">
            Every <code class="rounded bg-zinc-900 px-1.5 py-0.5 font-mono text-sm text-cyan-400">ansible-*</code> command.
            One guided interface. Zero context switching.
          </p>
        </div>

        <p class="max-w-md text-sm leading-relaxed text-zinc-500">
          Select an action, fill a form, preview the exact command, then execute with live output streaming,
          session context, job history, and 8 themes included.
        </p>

        <div class="flex max-w-[42rem] flex-wrap items-center gap-3">
          <a
            href="/install"
            class="inline-flex items-center gap-2 rounded-lg bg-cyan-400 px-5 py-2.5 text-sm font-semibold text-zinc-950 transition-colors hover:bg-cyan-300"
          >
            Get Started
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
          <a
            href="https://github.com/3A2DEV/ansi-tui"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-lg border border-zinc-700 bg-zinc-900 px-5 py-2.5 text-sm font-medium text-zinc-300 transition-all hover:border-zinc-500 hover:text-zinc-50"
          >
            <svg class="h-4 w-4" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
              <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z" />
            </svg>
            View on GitHub
          </a>
          <a
            href="https://www.npmjs.com/package/@3a2dev/ansi-tui"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-lg border border-zinc-700 bg-zinc-900 px-5 py-2.5 text-sm font-medium text-zinc-300 transition-all hover:border-zinc-500 hover:text-zinc-50"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path fill="currentColor" d="M1.763 0C.786 0 0 .786 0 1.763v20.474C0 23.214.786 24 1.763 24h20.474c.977 0 1.763-.786 1.763-1.763V1.763C24 .786 23.214 0 22.237 0zM5.13 5.323l13.837.019-.009 13.836h-3.464l.01-10.382h-3.456L12.04 19.17H5.113z" />
            </svg>
            View on npmjs
          </a>
        </div>

        <div class="flex w-full max-w-[42rem] items-center gap-2 px-1 py-1 font-mono text-sm">
          <span class="select-none text-zinc-600">$</span>
          <Typewriter
            messages={['npm install -g @3a2dev/ansi-tui']}
            writeSpeed={42}
            deleteSpeed={24}
            waitWritten={9000}
            waitDeleted={1200}
            class="command-typewriter text-cyan-400"
          />
        </div>
      </div>

      <div class="relative animate-slide-up">
        <div class="pointer-events-none absolute -inset-4 rounded-2xl bg-cyan-400/5 blur-2xl" aria-hidden="true"></div>

        <div class="terminal-frame relative shadow-2xl shadow-black/50">
          <div class="terminal-titlebar">
            <span class="terminal-dot bg-red-500"></span>
            <span class="terminal-dot bg-yellow-500"></span>
            <span class="terminal-dot bg-green-500"></span>
            <span class="ml-3 flex-1 select-none text-center font-mono text-xs text-zinc-500">
              ansi-tui — Ansible Terminal UI
            </span>
          </div>
          <div class="relative overflow-hidden bg-zinc-950">
            <Image
              src="/demo.gif"
              alt="ansi-tui demonstration showing tool navigation, form filling, command preview, and live execution"
              width={1344}
              height={1130}
              class="block h-auto w-full"
              loading="eager"
              decoding="async"
            />
          </div>
        </div>

        <div class="badge-cyan absolute -bottom-4 -left-4 shadow-lg shadow-cyan-400/10">{npmDownloadsLabel}</div>
        <div class="badge-violet absolute -right-4 -top-4 shadow-lg shadow-violet-500/10">8 themes</div>
      </div>
    </div>
  </div>
</section>
